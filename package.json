{
    "name": "samir.cx",
    "version": "2.0.0",
    "repository": "https://github.com/SamirTheSWE/samir.cx.git",
    "author": "contact@samir.cx",
    "license": "MIT",
    "private": true,
    "packageManager": "yarn@1.22.22",
    "scripts": {
        "postinstall": "husky",
        "format": "prettier --write .",
        "lint": "eslint .",
        "lint:fix": "yarn format && yarn lint --fix",
        "dev": "next dev --turbopack",
        "build": "next build",
        "start": "next start"
    },
    "lint-staged": {
        "*": [
            "yarn format"
        ],
        "*.ts": [
            "yarn lint:fix"
        ]
    },
    "dependencies": {
        "next": "16.2.2",
        "react": "19.2.4",
        "react-dom": "19.2.4"
    },
    "devDependencies": {
        "@eslint/eslintrc": "3.3.5",
        "@eslint/js": "10.0.1",
        "@next/eslint-plugin-next": "16.2.2",
        "@tailwindcss/postcss": "4.2.2",
        "@trivago/prettier-plugin-sort-imports": "6.0.2",
        "@tsparticles/engine": "3.9.1",
        "@tsparticles/react": "^3.0.0",
        "@tsparticles/slim": "3.9.1",
        "@types/node": "25.5.2",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "eslint": "10.1.0",
        "eslint-config-next": "16.2.2",
        "eslint-config-prettier": "10.1.8",
        "eslint-plugin-prettier": "5.5.5",
        "husky": "^9.1.7",
        "lint-staged": "16.4.0",
        "motion": "12.38.0",
        "postcss": "8.5.8",
        "prettier": "3.8.1",
        "prettier-plugin-tailwindcss": "0.7.2",
        "react-icons": "5.6.0",
        "tailwindcss": "4.2.2",
        "tsparticles": "3.9.1",
        "typescript": "6.0.2",
        "typescript-eslint": "8.58.0"
    }
}
